# This file will be committed, so DO NOT include any sensitive information.
# Use .env.local for local development environment variables.

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Database
# This will be automatically populated by the `provision_database` tool.
# For local development, you can use a local PostgreSQL database or a free tier from Neon.tech.
# Example: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@host:port/database"
